PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://news:news@localhost:5432/news

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Groq (free tier: https://console.groq.com)
GROQ_API_KEY=

# Optional: Hugging Face for classification fallback
HUGGINGFACE_API_KEY=

# Fetch interval cron (default: every 15 minutes)
FETCH_CRON=*/15 * * * *

# API response cache TTL in seconds
CACHE_TTL=300
